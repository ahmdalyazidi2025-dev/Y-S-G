rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // تم تحديث هذه الدالة فقط لتشمل حساب المشرف والموظفين بأمان تام ودون تخريب بقية القواعد
    function isAdmin() {
      return request.auth != null && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (exists(/databases/$(database)/documents/staff/$(request.auth.uid)) && (get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role == 'admin' || get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role == 'staff'))
      );
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    match /customers/{customerId} {
      allow read, write: if isAdmin();
      allow read, update: if request.auth != null && request.auth.uid == customerId;
    }

    match /staff/{staffId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null && request.auth.uid == staffId;
    }

    match /products/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /categories/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /banners/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /storeSettings/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /usernames/{docId} { allow read: if true; allow write: if isAdmin(); }

    // تم إضافة صلاحية التعديل والحذف لصاحب الفاتورة لتسهيل إدارة وإرسال المسودات بسلاسة
    match /orders/{orderId} {
      allow create: if true;
      allow read: if isAdmin() || (request.auth != null && resource.data.customerId == request.auth.uid);
      allow update, delete: if isAdmin() || (request.auth != null && resource.data.customerId == request.auth.uid);
    }

    match /requests/{requestId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    match /joinRequests/{requestId} {
      allow read, delete: if isAdmin();
      allow create: if false;
    }

    match /messages/{msgId} {
      allow create: if true; 
      allow read: if isAdmin() || (request.auth != null) || resource.data.userId.startsWith('guest_');
      allow update: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid) || resource.data.userId.startsWith('guest_');
      allow delete: if isAdmin();
    }
    
    match /notifications/{notifId} {
       allow read: if isAdmin() || (request.auth != null) || resource.data.userId.startsWith('guest_');
       allow create: if isAdmin() || request.auth != null;
       allow update: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid) || resource.data.userId.startsWith('guest_');
       allow delete: if isAdmin();
    }

    match /password_requests/{reqId} {
       allow create: if true;
       allow read, update, delete: if isAdmin();
    }

    match /coupons/{code} {
       allow read: if true;
       allow write: if isAdmin();
    }

    match /counters/{docId} {
      allow read, update: if true; 
      allow create: if isAdmin();
      allow delete: if false;
    }

    match /analytics_visits/{date} {
      allow read: if isAdmin();
      allow create, update: if true; 
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
